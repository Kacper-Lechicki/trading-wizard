# ============================================
# Trading Wizard — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to git. It contains secrets.
# ============================================

# --- Postgres (trading data storage) ---
POSTGRES_USER="trading_wizard"
POSTGRES_PASSWORD="CHANGE_ME_to_a_strong_password"
POSTGRES_DB="trading_wizard"
POSTGRES_PORT="5432"

# --- n8n ---
N8N_PORT="5678"
N8N_DEFAULT_USER_EMAIL="admin@local.host"
N8N_DEFAULT_USER_PASSWORD="CHANGE_ME_to_a_strong_password"
TIMEZONE="Europe/Warsaw"

# --- OpenRouter (AI — the only paid service) ---
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-your-key-here"

# --- FMP: Financial Modeling Prep (market data — free tier, 250 req/day) ---
# Get your key at: https://financialmodelingprep.com (sign up, dashboard)
FMP_API_KEY="your-fmp-key-here"

# --- Finnhub (news — optional, free tier, 60 req/min) ---
# Get your key at: https://finnhub.io (sign up, dashboard)
# Leave empty to skip Finnhub news (FMP news + Google RSS still work)
FINNHUB_API_KEY="your-finnhub-key-here"
